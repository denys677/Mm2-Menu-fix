local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LP = Players.LocalPlayer

-- GUI Setup
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 180, 0, 250)
MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Active = true
MainFrame.Draggable = true

local Title = Instance.new("TextLabel", MainFrame)
Title.Size = UDim2.new(1, 0, 0, 30)
Title.Text = "mm2 menu t.me/menu_script"
Title.TextColor3 = Color3.new(1, 1, 1)
Title.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Title.Parent = MainFrame

-- Функции
local Settings = {ESP = false, Autofarm = false, InfJump = false}

local function Toggle(name, pos, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = pos
    btn.Text = name
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.MouseButton1Click:Connect(function()
        Settings[name] = not Settings[name]
        btn.BackgroundColor3 = Settings[name] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(50, 50, 50)
        callback(Settings[name])
    end)
end

-- ESP LOGIC
RunService.Heartbeat:Connect(function()
    if not Settings.ESP then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local char = p.Character
            local highlight = char:FindFirstChild("High") or Instance.new("Highlight", char)
            highlight.Name = "High"
            if char:FindFirstChild("Knife") then highlight.FillColor = Color3.new(1,0,0) -- Мардер
            elseif char:FindFirstChild("Gun") then highlight.FillColor = Color3.new(0,0,1) -- Шериф
            else highlight.FillColor = Color3.new(0,1,0) end -- Мирный
        end
    end
end)

-- INF JUMP LOGIC
UserInputService.JumpRequest:Connect(function()
    if Settings.InfJump then
        LP.Character:FindFirstChild("Humanoid"):ChangeState("Jumping")
    end
end)

-- AUTOFARM LOGIC
task.spawn(function()
    while task.wait(0.3) do
        if Settings.Autofarm then
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name == "Coin" or v.Name == "Coin_Cent" then
                    LP.Character.HumanoidRootPart.CFrame = v.CFrame
                end
            end
        end
    end
end)

-- Кнопки в меню
Toggle("ESP", UDim2.new(0.05, 0, 0.15, 0), function(v) Settings.ESP = v end)
Toggle("Autofarm", UDim2.new(0.05, 0, 0.32, 0), function(v) Settings.Autofarm = v end)
Toggle("InfJump", UDim2.new(0.05, 0, 0.49, 0), function(v) Settings.InfJump = v end)
